<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1B2436"
    app:cardCornerRadius="12dp"
    app:strokeColor="#2D3748"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Avatar Circle -->
        <TextView
            android:id="@+id/tvFriendAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_icon_orange"
            android:gravity="center"
            android:text="?"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvFriendName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Friend Name"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tvFriendAvatar"
            app:layout_constraintTop_toTopOf="@id/tvFriendAvatar" />

        <!-- Friend Code -->
        <TextView
            android:id="@+id/tvFriendCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="friend code:"
            android:textColor="#718096"
            app:layout_constraintStart_toStartOf="@id/tvFriendName"
            app:layout_constraintTop_toBottomOf="@id/tvFriendName" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>