<?xml version="1.0" encoding="utf-8"?>
<!--
    NestedScrollView: Allows the entire screen to scroll as one unit.
    This is important because we have two lists (RecyclerViews) on one page.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121B2B"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- SECTION 1: HEADER & CREATE ACTION -->
        <TextView
            android:id="@+id/tvGroupsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Groups"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#000000"
            android:text="Create Group"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_add"
            app:layout_constraintBottom_toBottomOf="@id/tvGroupsHeader"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvGroupsHeader" />

        <!-- SECTION 2: PENDING INVITES
             Shows invitations from other users that haven't been accepted yet.
        -->
        <TextView
            android:id="@+id/tvPendingInvitesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending Invites"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvGroupsHeader"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- List for Group Invitations -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPendingInvites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvPendingInvitesLabel" />

        <!-- Placeholder shown only when inviteList is empty -->
        <TextView
            android:id="@+id/tvNoPendingInvites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="No pending invitations"
            android:textColor="#718096"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvPendingInvitesLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- SECTION 3: EXISTING GROUPS
             Shows groups where the current user is already a member.
        -->
        <TextView
            android:id="@+id/tvExistingGroupsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Existing Groups"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvPendingInvites" />

        <!-- Group List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGroupsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvExistingGroupsLabel" />

        <!-- Placeholder shown only when groupsList is empty -->
        <TextView
            android:id="@+id/tvNoGroups"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="You haven't joined any groups yet"
            android:textColor="#718096"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rvGroupsList" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>