<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <!-- The Main Dialog Card with Border -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/popupBorderCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeColor="#EF4444"
        app:strokeWidth="10dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="32dp">

            <!-- Colored Icon Background -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/iconContainer"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardBackgroundColor="#EF4444"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/popupIcon"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_stop"
                    app:tint="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Sender Name -->
            <TextView
                android:id="@+id/tvSenderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Mike Johnson"
                android:textColor="#718096"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iconContainer" />

            <!-- Signal Title -->
            <TextView
                android:id="@+id/tvSignalName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="40dp"
                android:layout_marginHorizontal="24dp"
                android:gravity="center"
                android:text="Signal\nPlaceHolder"
                android:textColor="#1A202C"
                android:textSize="36sp"
                android:textStyle="bold"
                android:lineSpacingExtra="-4dp"
                app:layout_constraintBottom_toTopOf="@id/signalTimerBar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSenderName" />

            <!-- Progress Bar (Timer) -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/signalTimerBar"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:progress="100"
                app:indicatorColor="#EF4444"
                app:trackColor="#E2E8F0"
                app:trackThickness="24dp"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>